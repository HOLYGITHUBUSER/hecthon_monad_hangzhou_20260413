# Monad Testnet RPC URL
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Your wallet private key (NEVER share this!)
PRIVATE_KEY=your_private_key_here

# Agent private key (optional, defaults to PRIVATE_KEY)
AGENT_PRIVATE_KEY=your_agent_private_key_here

# Teammate agent keys (for test-full)
AGENT_A_KEY=your_agent_a_private_key_here
AGENT_B_KEY=your_agent_b_private_key_here
AGENT_C_KEY=your_agent_c_private_key_here

# HTTPS proxy host IP (for demo)
HOST_IP=localhost

# Telegram Bot (optional, for approval notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
